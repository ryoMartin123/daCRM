# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEVER expose this key client-side:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google Maps / Address ────────────────────────────────
# Used client-side for Places Autocomplete.
# Restrict this key to your domain in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Used server-side only for Address Validation API.
# Never expose this key to the browser.
GOOGLE_ADDRESS_VALIDATION_KEY=

